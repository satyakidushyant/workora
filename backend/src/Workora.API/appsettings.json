{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=workora;Username=postgres;Password=admin;"
  },
  "CacheSettings": {
    "UseRedis": false,
    "RedisConnectionString": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "super-secret-key-that-must-be-very-long-for-hmac-sha256-minimum-256-bits",
    "Issuer": "Workora",
    "Audience": "WorkoraClient",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  }
}